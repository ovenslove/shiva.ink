    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "photoswipe": "^5.4.4",
    "pinia": "^2.1.7",
    "sass": "^1.77.2",
    "v-viewer": "^3.0.11",
    "viewerjs": "^1.11.6",
    "vue": "^3.5.0",
    "vue-lazyload": "^3.0.0",
    "vue-router": "^4.4.0"
