    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "husky": "^8.0.3",
    "jsdom": "^22.1.0",
    "prettier": "^3.2.5",
    "standard-version": "^9.5.0",
    "typescript": "^5.4.5",
    "vite": "^4.5.3",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^0.34.6",
    "vue-tsc": "^1.8.27"
